# Knowledge (accumulated per-user meta-learning)
knowledge/*
!knowledge/.gitkeep

# Validation results (user-specific evaluation outputs)
validation/results/*
!validation/results/.gitkeep

# PDF generation fonts (download via build script)
docs/pdf/fonts/
