{
  "_comment": "Schema for {results_dir}/ingest.json — self-contained manifest for website ingestion.",
  "session_id": "${SESSION_ID}",
  "mode": "${MODE}",
  "status": "success|partial|degraded|failed",
  "field_a": "${FIELD_A}",
  "field_c": "${FIELD_C}",
  "bridge_concepts": [],
  "strategy": "${STRATEGY}",
  "disjointness": "${DISJOINTNESS_SCORE — use mapping: DISJOINT=1.0, PARTIALLY_EXPLORED=0.6, PARTIALLY_CONNECTED=0.3}",
  "contributor_key": "${from .magellan/config.json if connected, otherwise null}",
  "started_at": "${ISO_TIMESTAMP — from metadata.start_time}",
  "completed_at": "${ISO_TIMESTAMP — current time}",
  "pipeline_stats": {
    "hypotheses_generated": "N",
    "survived_critique": "N",
    "passed_quality_gate": "N",
    "kill_rate": "N.N",
    "cycles_run": "N",
    "evolver_skipped": "BOOL"
  },
  "empirical_validation": {
    "_comment": "Optional — populated if convergence scanner and/or dataset evidence miner ran (v5.13)",
    "convergence_strong_count": "N (from convergence.json aggregate)",
    "convergence_moderate_count": "N",
    "dataset_confirmed_count": "N (from dataset-evidence.json aggregate)",
    "dataset_total_claims": "N",
    "empirical_evidence_score": "N.N (weighted: dataset 0.55, convergence 0.45)"
  },
  "_sources": {
    "status": "from state/session.json",
    "field_a_field_c_bridge_concepts_strategy": "from selected_target in state/session.json",
    "pipeline_stats": "from health counters in state/session.json",
    "contributor_key": "from .magellan/config.json"
  }
}
